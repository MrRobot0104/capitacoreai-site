{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/dashpilot-generate.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/voyagepilot-generate.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/vibeshieldpilot-scan.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/merakipilot-chat.js": {
      "memory": 512,
      "maxDuration": 120
    },
    "api/*.js": {
      "memory": 256,
      "maxDuration": 60
    }
  }
}
